---
// Language detection
const currentPath = Astro.url.pathname;
const isGerman = currentPath === "/de" || currentPath.startsWith("/de/");
const currentLang = isGerman ? "de" : "en";

// Navigation labels
const navItems = isGerman
  ? [
      { text: "Start", href: "/" },
      { text: "Über mich", href: "/about" },
      { text: "Coaching", href: "/coaching" },
      { text: "Workshops", href: "/workshops" },
      { text: "Preise", href: "/prices" },
      { text: "Kontakt", href: "/contact" },
    ]
  : [
      { text: "Home", href: "/" },
      { text: "About", href: "/about" },
      { text: "Coaching", href: "/coaching" },
      { text: "Workshops", href: "/workshops" },
      { text: "Prices", href: "/prices" },
      { text: "Contact", href: "/contact" },
    ];

// Create matching language URLs
const englishPath = isGerman ? currentPath.replace(/^\/de/, "") || "/" : currentPath;
const germanPath = isGerman ? currentPath : `/de${currentPath === "/" ? "" : currentPath}`;
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <div class="flex items-center space-x-8">
    <ul class="flex items-center space-x-6">
      {
        navItems.map((item) => {
          const isActive =
            currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href)) ||
            (isGerman &&
              (currentPath === `/de${item.href === "/" ? "" : item.href}` ||
                (item.href !== "/" && currentPath.startsWith(`/de${item.href}`))));
          
          const localizedHref =
            currentLang === "de"
              ? `/de${item.href === "/" ? "" : item.href}`
              : item.href;

          return (
            <li>
              <a
                href={localizedHref}
                class={`nav-link text-base font-medium transition-colors ${
                  isActive ? "greenDarkFont" : "blueFont"
                }`}
                aria-current={isActive ? "page" : undefined}
              >
                {item.text}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center text-sm font-medium border border-gray-200 rounded-md overflow-hidden">
      <a
        href={englishPath}
        class={`px-3 py-1.5 transition-colors ${
          currentLang === "en"
            ? "bg-emerald-50 greenDarkFont"
            : "blueFont hover:text-[#30B28E] hover:bg-gray-50"
        }`}
        aria-current={currentLang === "en" ? "true" : undefined}
      >
        EN
      </a>
      <a
        href={germanPath}
        class={`px-3 py-1.5 transition-colors border-l border-gray-200 ${
          currentLang === "de"
            ? "bg-emerald-50 greenDarkFont"
            : "blueFont hover:text-[#30B28E] hover:bg-gray-50"
        }`}
        aria-current={currentLang === "de" ? "true" : undefined}
      >
        DE
      </a>
    </div>
  </div>
</nav>

<!-- Mobile Menu Button -->
<button
  id="mobile-menu-button"
  class="lg:hidden p-2 text-gray-700 hover:text-[#30B28E] focus:outline-none transition-colors relative"
  aria-label={isGerman ? "Menü öffnen" : "Open menu"}
  aria-expanded="false"
  type="button"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 bg-white shadow-lg border-t border-gray-100 origin-top transition-all duration-200 ease-out lg:hidden z-50 opacity-0 pointer-events-none scale-y-95"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <div class="px-4 py-6">
    <div class="grid grid-cols-2 gap-3">
      {
        navItems.map((item) => {
          const isActive =
            currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href)) ||
            (isGerman &&
              (currentPath === `/de${item.href === "/" ? "" : item.href}` ||
                (item.href !== "/" && currentPath.startsWith(`/de${item.href}`))));

          const localizedHref =
            currentLang === "de"
              ? `/de${item.href === "/" ? "" : item.href}`
              : item.href;

          return (
            <a
              href={localizedHref}
              class={`block px-4 py-3 text-sm font-medium rounded-lg transition-colors text-center ${
                isActive
                  ? "bg-emerald-50 greenDarkFont border border-emerald-200"
                  : "text-gray-700 hover:bg-gray-50 hover:text-[#30B28E] border border-transparent"
              }`}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              {item.text}
            </a>
          );
        })
      }
    </div>

    <div class="mt-4 flex justify-center">
      <div class="flex items-center text-sm font-medium border border-gray-200 rounded-md overflow-hidden">
        <a
          href={englishPath}
          class={`px-4 py-2 transition-colors ${
            currentLang === "en"
              ? "bg-emerald-50 greenDarkFont"
              : "blueFont hover:text-[#30B28E] hover:bg-gray-50"
          }`}
        >
          EN
        </a>
        <a
          href={germanPath}
          class={`px-4 py-2 transition-colors border-l border-gray-200 ${
            currentLang === "de"
              ? "bg-emerald-50 greenDarkFont"
              : "blueFont hover:text-[#30B28E] hover:bg-gray-50"
          }`}
        >
          DE
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  #mobile-menu.show {
    opacity: 1;
    pointer-events: auto;
    transform: scaleY(1);
  }

  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }

  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }

  #mobile-menu a {
    transition: all 0.15s ease;
  }

  #mobile-menu a[aria-current="page"] {
    font-weight: 600;
  }
</style>

<script is:inline>
  (() => {
    let initialized = false;

    function initMobileMenu() {
      const mobileMenuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");

      if (!mobileMenuButton || !mobileMenu) return;
      if (mobileMenuButton.dataset.menuBound === "true") return;

      mobileMenuButton.dataset.menuBound = "true";

      let isMenuOpen = false;

      const openMenu = () => {
        mobileMenu.classList.add("show");
        mobileMenuButton.setAttribute("aria-expanded", "true");
        isMenuOpen = true;
      };

      const closeMenu = () => {
        mobileMenu.classList.remove("show");
        mobileMenuButton.setAttribute("aria-expanded", "false");
        isMenuOpen = false;
      };

      const toggleMenu = (event) => {
        event.preventDefault();
        event.stopPropagation();
        if (isMenuOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      };

      mobileMenuButton.addEventListener("click", toggleMenu);

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (
          isMenuOpen &&
          target instanceof Node &&
          !mobileMenu.contains(target) &&
          !mobileMenuButton.contains(target)
        ) {
          closeMenu();
        }
      });

      const navLinks = mobileMenu.querySelectorAll('a[href]');
      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          closeMenu();
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && isMenuOpen) {
          closeMenu();
        }
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024 && isMenuOpen) {
          closeMenu();
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initMobileMenu);
    } else {
      initMobileMenu();
    }

    document.addEventListener("astro:page-load", initMobileMenu);
  })();
</script>