---
import "../assets/styles/global.css";
import Seo from "../components/UI/Seo.astro";
import Header from "../components/Global/Header.astro";
import Footer from "../components/Global/Footer.astro";

export interface Props {
  title?: string;
  seoTitle?: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
  lang?: "en" | "de";
}

const {
  title = "Ariane Mader | Coaching & Counselling",
  seoTitle,
  description = "Coaching and counselling for procrastination, overwhelm, habit change, neurodivergence, and career clarity. Online and in person in Amsterdam and Almere.",
  image = {
    url: "/uploads/home-header.png",
    alt: "Ariane Mader - Coaching & Counselling",
  },
  type = "website",
  canonicalUrl,
  lang = "en",
} = Astro.props;

const finalTitle = title;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <Seo
      title={finalTitle}
      description={description}
      image={image}
      type={type}
      canonicalUrl={canonicalUrl}
      lang={lang}
    />
    
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <div class="flex flex-col min-h-screen">
      <Header />
      
      <main class="flex-grow">
        <slot />
      </main>
      
      <Footer />
    </div>
  </body>
</html>