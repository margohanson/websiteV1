  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const track = document.getElementById("t-track");
      const prevBtn = document.getElementById("t-prev");
      const nextBtn = document.getElementById("t-next");
      const dotsWrap = document.getElementById("t-dots");

      if (!track || !prevBtn || !nextBtn || !dotsWrap) return;

      const slides = Array.from(track.querySelectorAll("li"));
      const total = slides.length;
      let index = 0;

      const buildDots = () => {
        dotsWrap.innerHTML = "";
        slides.forEach((_, i) => {
          const b = document.createElement("button");
          b.type = "button";
          b.className =
            "h-2.5 w-2.5 rounded-full transition-colors " +
            (i === index ? "bg-[#193472]" : "bg-gray-300 hover:bg-gray-400");
          b.setAttribute("aria-label", `Go to testimonial ${i + 1} of ${total}`);
          b.addEventListener("click", () => goTo(i));
          dotsWrap.appendChild(b);
        });
      };

      const updateDisabled = () => {
        prevBtn.disabled = index <= 0;
        nextBtn.disabled = index >= total - 1;

        const dotButtons = Array.from(dotsWrap.querySelectorAll("button"));
        dotButtons.forEach((b, i) => {
          b.className =
            "h-2.5 w-2.5 rounded-full transition-colors " +
            (i === index ? "bg-[#193472]" : "bg-gray-300 hover:bg-gray-400");
        });
      };

      const goTo = (i) => {
        index = Math.max(0, Math.min(total - 1, i));
        slides[index].scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
        updateDisabled();
      };

      prevBtn.addEventListener("click", () => goTo(index - 1));
      nextBtn.addEventListener("click", () => goTo(index + 1));

      let scrollTimeout;
      track.addEventListener("scroll", () => {
        window.clearTimeout(scrollTimeout);
        scrollTimeout = window.setTimeout(() => {
          const trackLeft = track.getBoundingClientRect().left;
          let best = 0;
          let bestDist = Infinity;

          slides.forEach((li, i) => {
            const rect = li.getBoundingClientRect();
            const dist = Math.abs(rect.left - trackLeft);
            if (dist < bestDist) {
              bestDist = dist;
              best = i;
            }
          });

          index = best;
          updateDisabled();
        }, 80);
      });

      const setUniformHeights = () => {
        const testimonialBoxes = document.querySelectorAll("#testimonials .testimonial-box");
        if (!testimonialBoxes.length) return;

        testimonialBoxes.forEach((box) => {
          box.style.height = "auto";
        });

        let maxHeight = 0;
        testimonialBoxes.forEach((box) => {
          const height = box.offsetHeight;
          if (height > maxHeight) maxHeight = height;
        });

        testimonialBoxes.forEach((box) => {
          box.style.height = `${maxHeight}px`;
        });
      };

      const detailsBlocks = document.querySelectorAll("#testimonials details");

      detailsBlocks.forEach((details) => {
        details.addEventListener("toggle", () => {
          const testimonialBoxes = document.querySelectorAll("#testimonials .testimonial-box");
          const anyOpen = Array.from(detailsBlocks).some((d) => d.open);

          if (anyOpen) {
            testimonialBoxes.forEach((box) => {
              box.style.height = "auto";
            });
          } else {
            setUniformHeights();
          }
        });
      });

      buildDots();
      updateDisabled();
      setTimeout(setUniformHeights, 100);

      let resizeTimeout;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimeout);

        resizeTimeout = setTimeout(() => {
          const anyOpen = Array.from(detailsBlocks).some((d) => d.open);
          if (!anyOpen) {
            setUniformHeights();
          }
        }, 250);
      });
    });
  </script>

  <style>
    #testimonials .testimonial-box {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      min-height: 400px;
      display: flex;
      flex-direction: column;
    }

    #testimonials p {
