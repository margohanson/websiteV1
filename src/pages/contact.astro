---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="Contact | Ariane Mader"
  seoTitle="Contact | Book a Free Intro Call"
  description="Get in touch with Ariane Mader to ask questions or book a free 30-minute introduction call for coaching or counselling."
  canonicalUrl="https://arianemader.com/contact"
  lang="en"
  alternateEn="https://arianemader.com/contact"
  alternateDe="https://arianemader.com/de/contact"
  xDefault="https://arianemader.com/contact"
>
  <PageHeader 
    title="Contact Me" 
    subtitle="I'd love to hear from you!"
    backgroundImage="/uploads/about-header.jpg"
    overlayOpacity={0.3}
  />
  



  <!-- Contact Info -->
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-12 items-center">
        <!-- Contact Form -->
        <div>
          <h2 class="text-3xl blueFont font-bold mb-6">Get in Touch</h2>

          <div class="prose prose-lg max-w-none">
            <p>
              If you are curious about working together, have questions, or want to explore if coaching is right for you, feel free to reach out.<br>
              I offer a <b>free 30-minute introduction video call</b>, during which we will clarify what you are struggling with, explore what might help, and see if we are a good fit.
            </p>

            <p>You can contact me at:</p>
          </div>

          <!-- Email row (kept OUTSIDE prose paragraph) -->
          <div class="not-prose flex items-center gap-2 mt-2 text-lg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 greenDarkFont flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>

            <a
              href="mailto:info@arianemader.com"
              class="text-gray-800 hover:text-gray-600 transition-colors"
            >
              info<span aria-hidden="true">[at]</span><span class="sr-only">@</span>arianemader.com
            </a>
          </div>

          <div class="prose prose-lg max-w-none">
            <p class="mt-6">I look forward to hearing from you!</p>
          </div>
        </div>
          <img 
  src="/uploads/contact1.jpg" 
  alt="Contact image"
  class="rounded-lg shadow-lg object-cover w-full max-w-sm max-h-[380px] mx-auto"
 />
        <div >
        </div>
      </div>
    </div>
  </section>

</BaseLayout>