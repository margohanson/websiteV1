---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="Prices | Ariane Mader"
  seoTitle="Prices | Coaching, Counselling & Workshops"
  description="View prices for individual coaching, counselling, and workshops with Ariane Mader. Online and in person in Amsterdam and Almere."
  canonicalUrl="https://arianemader.com/prices"
  lang="en"
>
  <PageHeader 
    title="Prices" 
    backgroundImage="/uploads/prices-header2.jpg"
    overlayOpacity={0.2}
  />
  
  <!-- Prices -->
<section class="py-16 bg-white">
  <div class="w-full">
    <div class="px-6 md:px-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Individuals -->
        <div class="p-4">
          <div class="prose prose-lg max-w-none prose-p:my-2">
            <h3 class="blueFont text-center">Coaching for Individuals</h3>

            <p class="text-gray-700 text-center">
              <strong>60 minutes — 85€ (incl. VAT)</strong><br />
              Standard coaching session
            </p>

            <p class="text-gray-700 text-center">
              <strong>90 minutes — 115€ (incl. VAT)</strong><br />
              Deep-dive or methodology session (e.g. Ikigai, Logic Levels)
            </p>
          </div>
        </div>

        <!-- Discounts -->
<div class="p-4">
  <div class="relative">
    <div class="absolute inset-0 -top-5 rounded-lg border border-gray-200"></div>

    <div class="relative prose prose-lg max-w-none text-center px-5 pt-0 pb-6">
      <h3 class="blueFont text-center mt-0 mb-3">
        Discounts
      </h3>

      <p class="text-gray-700 my-0">
        <strong>Online sessions:</strong> 10€ less<br />
        <strong>Students or unemployed:</strong> 20% discount<br />
        <strong>Referral:</strong> both receive 20€ off the next session
      </p>
    </div>
  </div>
</div>

        <!-- Organisations -->
        <div class="p-4">
          <div class="prose prose-lg max-w-none prose-p:my-2">
            <h3 class="blueFont text-center">Organisations and Companies</h3>

            <p class="text-gray-700 text-center">
              <b>Individual coaching:</b> from 130€ / hour (excl. VAT).
            </p>

            <p class="text-gray-700 text-center">
              <b>Workshops and training:</b> tailored pricing depending on format and scope.
              Please
              <a
                href="/contact"
                class="font-medium underline transition-colors text-[#193472] hover:!text-[#30B28E]"
              >reach out</a>
              to discuss your needs.
            </p>
          </div>
        </div>
      </div>

      <!-- Full-width centered bottom text -->
      <div class="mt-12">
        <div class="prose prose-lg max-w-none text-center">
          <p>
            Sessions are available in-person (Almere or Amsterdam) and online.<br />
            The session number is flexible. Some people come for a few focused sessions and others work with me over a longer period of time.
          </p>

          <p>
            If you are curious about coaching, have questions, or want to explore if this is right for you, feel free to
            <a
              href="/contact"
              class="font-medium underline transition-colors text-[#193472] hover:!text-[#30B28E]"
            >reach out</a> for a free 30-minute introduction call.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>