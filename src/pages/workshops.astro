---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import StaffList from "../components/Sections/StaffList.astro";
import { Carousel } from 'webcoreui/astro'
---

<BaseLayout
  title="Workshops | Ariane Mader"
  seoTitle="Workshops for Universities & Organisations | Ariane Mader"
  description="Interactive workshops on procrastination, stress, habits, inclusivity, communication, and team dynamics for universities and organisations."
  canonicalUrl="https://arianemader.com/workshops"
  lang="en"
  alternateEn="https://arianemader.com/workshops"
  alternateDe="https://arianemader.com/de/workshops"
  xDefault="https://arianemader.com/workshops"
>
  <PageHeader 
    title="Workshops" 
    subtitle="Tailored to your Organisation or Group"
    backgroundImage="/uploads/workshops-header.jpg"
    overlayOpacity={0.35}
  />
  
  
  <!-- About Me/Ariane -->
   <!-- add diversity and inclusion and intercultural communication in future-->
  <section class="py-12 pb-12 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto prose prose-lg">
        <p>
            I design and deliver interactive workshops for universities, organisations, and teams.
        </p>
        <p>
          Workshops combine clear, accessible theory (psychoeducation), practical reflection and exercises, and concrete tools participants can directly apply. The goals is not just insight, but <b>useable change</b>.
        </p>
        <p>
            Workshops are <b>designed collaboratively</b> to match your context, needs, and goals. Depending on your preferences, sessions can be more interactive or more theory-focused.
        </p>
      </div>
    </div>
  </section>

<section class="py-12 bg-white">
  <div class="container">
    <div class="max-w-5xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-8">
        <h3 class="blueFont font-[Cambria]">Example Workshop Themes</h3>
      </div>

      <!-- Grid -->
      <div class="prose prose-lg max-w-none">
        <ul class="green-bullets grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-10 [&>li]:my-0">
          <li>Habit Change and Sustainable Routines</li>
          <li>Overcoming Procrastination</li>
          <li>Managing Stress and Overwhelm</li>
          <li>Inclusivity and Understanding Differences</li>
          <li>Team Dynamics and Communication</li>
          <li>Career Clarity Sessions</li>
          <!--<li>Academic Writing</li>-->
        </ul>
      </div>

    </div>
  </div>
</section>

  <section class="py-12 bg-gray-50">
  <div class="container">
    <div class="text-center mb-8">
      <h3 class="blueFont font-[Cambria]">How Workshops are Designed</h3>
    </div>

    <div class="max-w-3xl mx-auto prose prose-lg prose-p:my-3">
      <ol class="list-decimal ml-6 space-y-4 green-numbers">
        <li>
          <strong>Initial Conversation</strong><br />
          After you reach out, we schedule a conversation to discuss your goals, context, and needs.
        </li>
        <li>
          <strong>Proposal</strong><br />
          Based on our conversation, I prepare a tailored plan and price estimate.
        </li>
        <li>
          <strong>Preparation</strong><br />
          Once we decide to work together, I further develop the workshop content to fit your group.
        </li>
        <li>
          <strong>Workshop Delivery</strong><br />
          During the workshop, I create a safe and inclusive atmosphere. I 
          facilitate the interactive session with structure, while staying responsive to
          the group, allowing the programme to adapt to emerging needs.
        </li>
        <li>
          <strong>Follow-up</strong><br />
            After the workshop, we reflect on how it went.
            Optionally, we discuss next steps or follow-up
            sessions to support further learning or change.
        </li>
      </ol>
    </div>
  </div>
</section>

  <!-- Pricing -->
   <!-- add diversity and inclusion and intercultural communication in future-->
  <section class="py-12 bg-white">
  <div class="container">
    <div class="max-w-4xl mx-auto prose prose-lg prose-p:my-3 text-center">
      
      <h3 class="blueFont text-center">Pricing</h3>

      <p>
        Pricing depends on format, scope, and group size.<br>
        Please reach out to discuss your needs.
      </p>

      <div class="flex flex-wrap justify-center gap-4 mt-6">
        <a 
          href="/contact" 
          class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-white bg-[#193472] rounded-md shadow-sm hover:bg-[#142a5e] focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          Contact Me
        </a>
      </div>

    </div>
  </div>
</section>

</BaseLayout>